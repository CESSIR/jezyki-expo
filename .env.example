# =============================================================================
# WeatherNow — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values.
# SECURITY: Never commit .env to version control!
#
# Open-Meteo API does NOT require an API key for the free tier.
# This file exists as a best practice template for future extensibility.
# =============================================================================

# Example: If we ever switch to a paid weather API
# WEATHER_API_KEY=your_api_key_here
